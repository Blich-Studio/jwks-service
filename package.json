  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite-node --watch src/main.ts",
    "start:dev": "vite-node --watch src/main.ts",
    "build": "vite build",
    "start": "node dist/server.mjs",
    "preview": "node dist/server.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
