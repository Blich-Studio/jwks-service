PORT=3100
JWT_ISSUER=https://jwks.blichstudio.com
JWT_AUDIENCE=blich-api
JWT_KID=local-key-1
JWT_EXPIRES_IN=15m
JWKS_CACHE_MAX_AGE=300
TOKEN_API_KEY=replace-with-long-random-string
# Use either GOOGLE_PRIVATE_KEY_SECRET (preferred in production) or LOCAL_* keys when running locally
GOOGLE_PRIVATE_KEY_SECRET=projects/your-project/secrets/auth-issuer-private-key-rsa/versions/latest
LOCAL_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nbase64==\n-----END PRIVATE KEY-----"
LOCAL_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nbase64==\n-----END PUBLIC KEY-----"
